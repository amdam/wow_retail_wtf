["var_name"] = "trinket_2_stronger",
},
{
["enabled"] = true,
["op"] = "set",
["action"] = "variable",
["value"] = "buff.lead_from_the_front.duration * ( 1 + ( 1 / ( 2 * gcd.max ) ) )",
["description"] = "If the natural summon CD is longer than this, we won't get 2 stampedes /w Season 3 tier set",
["var_name"] = "double_stampede",
},
