["criteria"] = "remains <= buff.ca_inc.duration & variable.pool_for_cd || remains <= buff.ca_inc.up & ! buff.dryads_favor.up",
},
{
["enabled"] = true,
["action"] = "wrath",
["description"] = "Wrath to pool AP before using CDs",
