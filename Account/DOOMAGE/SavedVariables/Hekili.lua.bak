},
{
["enabled"] = true,
["criteria"] = "! variable.enter_lunar & eclipse.in_eclipse & eclipse.remains < cast_time & ! buff.dryads_favor.up & ( ! variable.kotg_ca_condition || ! variable.kotg_inc_condition )",
["action"] = "starfire",
},
{
