["action"] = "moonfire",
["cycle_targets"] = 1,
},
{
["enabled"] = true,
["criteria"] = "cooldown.convoke_the_spirits.remains < gcd.max * 2 & variable.convoke_condition & astral_power > action.starsurge.cost & buff.dryad.remains > 4 + gcd.max & buff.dryad.up & fight_remains > 5",
["action"] = "starsurge",
},
