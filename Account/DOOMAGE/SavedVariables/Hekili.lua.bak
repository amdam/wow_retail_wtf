},
{
["enabled"] = true,
["criteria"] = "talent.demonic_soul.enabled & ( soul_shard > 2 || buff.tormented_crescendo.up & cooldown.soul_rot.remains > buff.tormented_crescendo.remains * gcd.max ) & ( ! talent.vile_taint.enabled || soul_shard > 1 & cooldown.vile_taint.remains > 10 )",
