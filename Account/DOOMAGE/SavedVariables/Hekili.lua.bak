["Arcane"] = {
["source"] = "https://github.com/simulationcraft/simc/blob/thewarwithin/ActionPriorityLists/default/mage_arcane.simc",
["builtIn"] = true,
["date"] = 20250829.1,
["spec"] = 62,
["desc"] = "2025-08-29: Sync with SimC\n\n2025-08-12: Sync with SimC\n\n2025-08-05: First APL",
["lists"] = {
["cd_opener"] = {
{
["enabled"] = true,
["criteria"] = "prev_gcd.1.arcane_surge || ( cooldown.arcane_surge.remains > 30 & cooldown.touch_of_the_magi.ready & ( ( buff.arcane_charge.stack < 4 & ! prev_gcd.1.arcane_barrage ) || prev_gcd.1.arcane_barrage ) ) || boss & fight_remains < 15",
["use_off_gcd"] = 1,
["description"] = "Touch of the Magi used if you just used Arcane Surge, the wait simulates the time it takes to queue another spell after Touch when you Surge into Touch, otherwise we'll Touch off cooldown either after Barrage or if we just need Charges.",
["action"] = "touch_of_the_magi",
},
{
["enabled"] = true,
["criteria"] = "buff.presence_of_mind.up",
["action"] = "arcane_blast",
},
{
["enabled"] = true,
["criteria"] = "talent.high_voltage.enabled & variable.opener",
["line_cd"] = "10",
["description"] = "Use Orb for Charges on the opener if you have High Voltage as the Missiles will generate the remaining Charge you need",
["action"] = "arcane_orb",
},
{
["enabled"] = true,
["criteria"] = "buff.arcane_tempo.up & cooldown.evocation.ready & buff.arcane_tempo.remains < gcd.max * 5",
["line_cd"] = "11",
["description"] = "Barrage before Evocation if Tempo will expire",
["action"] = "arcane_barrage",
},
{
["enabled"] = true,
["criteria"] = "cooldown.arcane_surge.remains < ( gcd.max * 3 ) & cooldown.touch_of_the_magi.remains < ( gcd.max * 5 ) || fight_remains < 25",
["action"] = "evocation",
},
{
["enabled"] = true,
["action"] = "arcane_missiles",
["interrupt_immediate"] = "1",
["interrupt_global"] = "1",
["criteria"] = "( prev_gcd.1.evocation || prev_gcd.1.arcane_surge || variable.opener ) & buff.nether_precision.down",
["line_cd"] = "30",
["interrupt_if"] = "tick_time>gcd.remains&buff.aether_attunement.down",
["description"] = "Use Missiles to get Nether Precision up for your burst window, clipping logic applies as long as you don't have Aether Attunement.",
["chain"] = "1",
},
{
["enabled"] = true,
["criteria"] = "cooldown.touch_of_the_magi.remains < ( action.arcane_surge.execute_time + ( gcd.max * ( buff.arcane_charge.stack = 4 ) ) ) || boss & fight_remains < 25",
["action"] = "arcane_surge",
