},
{
["enabled"] = true,
["criteria"] = "( buff.fatebound_coin_tails.stack > 0 & buff.fatebound_coin_heads.stack > 0 ) || debuff.shiv.up & ( cooldown.deathmark.remains > 50 & ( ! set_bonus.tww3_fatebound_4pc ) || dot.kingsbane.ticking & ( set_bonus.tww3_fatebound_4pc ) || ! talent.inevitabile_end.enabled & effective_combo_points >= variable.effective_spend_cp )",
["use_off_gcd"] = 1,
["action"] = "cold_blood",
["description"] = "Cold Blood for Edge Case or Envenoms during shiv",
},
