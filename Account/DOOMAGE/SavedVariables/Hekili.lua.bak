["spellslinger"] = {
{
["enabled"] = true,
["criteria"] = "( ( ( ( ( action.arcane_orb.charges = 0 ) & cooldown.arcane_orb.remains > 16 ) || cooldown.touch_of_the_magi.remains < 20 ) & buff.arcane_surge.down & buff.siphon_storm.down & debuff.touch_of_the_magi.down & ( buff.intuition.down || ( buff.intuition.up & buff.intuition.remains > cast_time ) ) & cooldown.touch_of_the_magi.remains > ( 12 + 6 * gcd.max ) ) || ( prev_gcd.1.arcane_barrage & talent.shifting_shards.enabled & ( buff.intuition.down || ( buff.intuition.up & buff.intuition.remains > cast_time ) ) & ( buff.arcane_surge.up || debuff.touch_of_the_magi.up || cooldown.evocation.remains < 20 ) ) ) & fight_remains > 10 & ( buff.arcane_tempo.remains > gcd.max * 2.5 || buff.arcane_tempo.down )",
["action"] = "shifting_power",
["description"] = "With Shifting Shards we can use Shifting Power whenever basically favoring cooldowns slightly, without it though we want to use it outside of cooldowns, don't cast if it'll conflict with Intuition expiration.",
},
{
["enabled"] = true,
["action"] = "cancel_buff",
