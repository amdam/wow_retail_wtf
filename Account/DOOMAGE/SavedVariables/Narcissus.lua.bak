[1304] = "::description::Held in the armory of Silvermoon, these High Elven blades remind them of their noble past.::price::160::transmogSetID::0::quality::2::perksVendorCategoryID::1::invType::INVTYPE_2HWEAPON::mountID::0::itemModifiedAppearanceID::302323::speciesID::0::name::Quel'dorei Poleblade::itemID::262373::addedDate::2026/38::",
[933] = "::description::Discover what it's like to be a pyromaniac.::price::300::transmogSetID::0::quality::3::perksVendorCategoryID::1::invType::INVTYPE_WEAPON::mountID::0::itemModifiedAppearanceID::230835::speciesID::0::name::Crimson Lunar Firewhacker::itemID::233232::addedDate::2026/38::",
[1299] = "::description::Ornate because close combat is basically a forced fashion show.::price::130::transmogSetID::0::quality::2::perksVendorCategoryID::1::invType::INVTYPE_WEAPON::mountID::0::itemModifiedAppearanceID::302319::speciesID::0::name::Sindorei Handglaive::itemID::262369::addedDate::2026/38::",
[932] = "::description::Slice through enemies and obstacles with ease.::price::300::transmogSetID::0::quality::3::perksVendorCategoryID::1::invType::INVTYPE_WEAPON::mountID::0::itemModifiedAppearanceID::230827::speciesID::0::name::Jade Lunar Blade::itemID::233223::addedDate::2026/38::",
[944] = "::description::The Silvermoon color scheme for the \"Motion By Emotion\" has been a success all across Azeroth.::price::600::transmogSetID::0::mountTypeName::Flying::quality::4::perksVendorCategoryID::2::invType::INVTYPE_NON_EQUIP_IGNORE::mountID::2329::itemModifiedAppearanceID::0::speciesID::0::name::Silvermoon Sweeper::itemID::233023::addedDate::2026/38::",
[942] = "::description::The Fullbelly meeksi will often put their own safety at risk if they smell food. Nothing brings them happiness like a cup of tea and a warm meal.::price::350::transmogSetID::0::quality::3::perksVendorCategoryID::3::invType::INVTYPE_NON_EQUIP_IGNORE::mountID::0::itemModifiedAppearanceID::0::speciesID::4729::name::Fullbelly Rollingpaw::itemID::234397::addedDate::2026/38::",
